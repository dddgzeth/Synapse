# ── Chat/pipeline LLM backend ────────────────────────────────────────
# Default is fucheers. The app runs with ONLY the fucheers vars below set;
# openai/anthropic are opt-in (set LLM_PROVIDER or pick in the UI).
LLM_PROVIDER=fucheers        # fucheers | openai | anthropic

# fucheers (default, required for the app to run)
ANTHROPIC_BASE_URL=https://www.fucheers.top
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# openai (optional — only used when LLM_PROVIDER=openai or chosen in UI)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# anthropic direct (optional — dedicated vars so they don't clash with the
# fucheers-repurposed ANTHROPIC_* above)
ANTHROPIC_DIRECT_API_KEY=
ANTHROPIC_DIRECT_MODEL=claude-sonnet-4-6
ANTHROPIC_DIRECT_BASE_URL=

MIROMIND_BASE_URL=https://api.miromind.ai/v1
MIROMIND_API_KEY=
MIROMIND_MODEL=mirothinker-1-7-deepresearch-mini

TDAI_DATA_DIR=./data

NOVAI_BASE_URL=
NOVAI_API_KEY=
GEMINI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AUTH_TEST_EMAIL=
AUTH_TEST_PASSWORD=
